# Supabase project settings (Settings > API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=              # Project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=         # anon/public key — safe to expose to the browser
SUPABASE_SERVICE_ROLE_KEY=             # service_role key — server-side only, NEVER expose to the browser
